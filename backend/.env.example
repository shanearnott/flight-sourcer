# Amadeus API (https://developers.amadeus.com - Self-Service tier, free)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test   # 'test' or 'production'

# Seat.aero Partner API (https://seat.aero - paid partner access)
SEAT_AERO_API_KEY=your_seat_aero_api_key

# Email alerts (SMTP settings)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=FlightSourcer <your@gmail.com>

# Server
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/flights.db
